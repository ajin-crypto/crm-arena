# ─────────────────────────────────────────────
# CRM Arena — Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── Frontend ──────────────────────────────────
# Dev: http://localhost:8000
# Prod: https://crm-arena-production.up.railway.app
VITE_API_URL=http://localhost:8000

# ── Backend ───────────────────────────────────
# Dev: sqlite:///./crm_arena.db
# Prod: postgresql://user:password@host/dbname  (from Neon dashboard)
DATABASE_URL=sqlite:///./crm_arena.db

# CORS — comma-separated list of allowed frontend origins
# Dev: http://localhost:5173
# Prod: https://crm-arena.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://crm-arena.vercel.app

# ── Integrations (optional) ───────────────────
APOLLO_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CALENDLY_API_KEY=
